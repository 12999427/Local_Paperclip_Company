{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "XXXXXXXXXX"
      },
      "models": {
        "z-ai/glm-5.2": { "name": "GLM 5.2" },
        "openai/gpt-oss-120b:free": { "name": "GPT-OSS 120B (free)" }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "llama3.2:latest": { "name": "Llama 3.2 (3B)" },
        "llama3.2:3b": { "name": "Llama 3.2 3B" },
        "gemma4:e4b": { "name": "Gemma 4 E4B" },
        "gemma4:26b": { "name": "Gemma 4 26B" },
        "qwen2.5-coder:14b": { "name": "Qwen 2.5 Coder 14B" },
        "qwen3.5:latest": { "name": "Qwen 3.5" }
      }
    }
  }
}
